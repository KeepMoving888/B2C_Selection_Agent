# ============================================================
# .env.example — 环境变量模板
# 复制为 .env 并填入真实值
# ============================================================

# ── 运行环境 ──────────────────────────────────────────
APP_ENV=development
# development | staging | production

# ── LLM API（生产必须）─────────────────────────────────
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# 说明：本项目用 v4-pro / v4-flash 做抽象路由层级（见 harness/model_router.py）。
# DeepSeek V4 系列已发布，官方模型 ID 为 deepseek-v4-pro（旗舰推理）和
# deepseek-v4-flash（高速轻量）。旧别名 deepseek-reasoner / deepseek-chat
# 计划于 2026-07-24 退役，新集成应直接使用下方 V4 模型名。
DEEPSEEK_PREMIUM_MODEL=deepseek-v4-pro     # 项目 v4-pro 映射的实际模型
DEEPSEEK_FLASH_MODEL=deepseek-v4-flash     # 项目 v4-flash 映射的实际模型

# ── 本地 vLLM 服务（OpenAI 兼容）────────────────────────
# Agent / 前端直接调用地址
VLLM_ORPO_URL=http://localhost:8000/v1
VLLM_BASE_URL=http://localhost:8001/v1

# API Gateway 后端地址（部署 systemd / docker-compose 时使用）
VLLM_AWQ_URL=http://127.0.0.1:8002
VLLM_FP16_URL=http://127.0.0.1:8003
GATEWAY_PORT=8080

# ── 模型路由 / 监控 ────────────────────────────────────
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2
# 监控 /metrics 端口，避免与系统 Prometheus 9090 冲突，固定 9091
METRICS_PORT=9091

# ── RAG 检索（可选，缺失则使用内存索引）──────────────────
OUTPUT_DIR=./output
FINETUNE_DATA_DIR=./finetune/data
# HF_TOKEN=your-huggingface-token

# ModelScope 访问令牌（上传/下载模型时使用）
# 获取地址：https://www.modelscope.cn/my/myaccesstoken
MODELSCOPE_ACCESS_TOKEN=your-modelscope-access-token

# ── 微调基座模型 ───────────────────────────────────────
# 默认使用 HuggingFace 标识符；在国内建议先通过 ModelScope 下载到本地后改为本地路径
# 例如：BASE_MODEL=./models/qwen/Qwen2.5-7B
BASE_MODEL=Qwen/Qwen2.5-7B

# ── 飞书集成（闭环必须）─────────────────────────────────
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=your-app-secret
FEISHU_BASE_TOKEN=your-base-token
FEISHU_TABLE_ID=your-table-id
FEISHU_WIKI_SPACE_ID=your-wiki-space-id
FEISHU_USER_OPEN_ID=ou_xxxxxxxxxxxx        # 文档所有者（openid/email/userid）
FEISHU_USER_MEMBER_TYPE=openid             # openid | email | userid
# 个人授权 token（强烈建议配置）。配置后文档将以个人名义创建，个人可直接编辑。
# 获取方式：
#   1. 进入飞书开放平台 https://open.feishu.cn/app/{your_app_id}/credentials
#   2. 在「凭证与基础信息」找到「用户访问令牌」调试工具；
#   3. 或自建 OAuth 流程（scope 需包含 docx:document 与 drive:drive），
#      回调后换取 user_access_token，有效期约 2 小时，到期后需重新获取。
FEISHU_USER_ACCESS_TOKEN=u-xxxxxxxxxxxx
FEISHU_APPROVAL_CODE=your-approval-code
FEISHU_REPORT_FOLDER_TOKEN=your-folder-token
FEISHU_NOTIFY_CHAT_ID=oc_xxxxxxxxxxxx

# ── Amazon 数据源（三选一，mock 离线模式无需 API 凭证）────────────
# 方案 A：Rainforest API（当前默认，免费试用，无需 Amazon 店铺账户）
# 注册地址：https://www.rainforestapi.com
RAINFOREST_API_KEY=your-rainforest-api-key

# 方案 B：Amazon Product Advertising API v5（生产官方接口，需 Associate 账户）
# 注册地址：https://affiliate-program.amazon.com/
AMAZON_PA_API_KEY=your-amazon-pa-api-key
AMAZON_PA_API_SECRET=your-amazon-pa-api-secret
AMAZON_PARTNER_TAG=your-partner-tag

# ── 1688 / Alibaba API（可选）──────────────────────────
ALIBABA_APP_KEY=your-alibaba-app-key
ALIBABA_APP_SECRET=your-alibaba-app-secret

# ── WandB 实验追踪（可选，设置 WANDB_API_KEY 后自动启用）──
# 注册地址：https://wandb.ai
WANDB_API_KEY=your-wandb-api-key
WANDB_PROJECT=b2c-product-selection
WANDB_RUN_GROUP=orpo-qwen2.5-7b
WANDB_RUN_NAME=qwen2.5-7b-orpo-ecommerce-v1

# ── Grafana / Docker（可选）────────────────────────────
GRAFANA_PASSWORD=admin
DOCKER_REGISTRY=your-registry.example.com
