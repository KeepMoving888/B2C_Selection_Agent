# ============================================================
# .gitignore — 跨境电商 Multi-Agent 智能选品系统
#
# 仓库仅托管源代码、配置、文档与少量必要产物。
# 模型权重、训练 checkpoint、实验日志等大文件由外部对象存储承担
# （HuggingFace Hub / ModelScope / WandB 云端）。
# ============================================================

# ── 面试/求职相关材料（不进入公开仓库）──
docs/resume_summary.md

# ── Secrets / 环境变量（含真实 API Key，严禁提交）──
.env
.env.local
.env.*.local
*.key
*.pem
secrets.yaml

# ── Python 编译缓存 ──
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.eggs/
build/
dist/
develop-eggs/

# ── 测试与类型检查缓存 ──
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/

# ── 大模型权重（15GB+，托管在 HuggingFace / ModelScope）──
models/
!models/.gitkeep
*.safetensors
*.bin
*.pt
*.pth
*.gguf
*.onnx
*.gguf.tmp

# ── 训练 checkpoint 与 optimizer 状态 ──
output/qwen2.5-7b-orpo-ecommerce-v1/checkpoint-*/
output/qwen2.5-7b-orpo-ecommerce-v1/adapter/
output/*/checkpoint-*/
output/*/adapter/
runs/

# ── WandB / TensorBoard 实验追踪（本地含绝对路径，不可提交）──
wandb/
wandb-debug.log
tb_logs/
lightning_logs/

# ── 向量库与缓存 ──
chroma_db/
*.duckdb
*.parquet
.cache/

# ── 运行时日志 ──
logs/
*.log
*.log.*
*.out

# ── 历史报告产物与运行时输出（保留示例，其余运行残留排除）──
output/*.json
output/execution_summary*.md
output/*/
!output/.gitkeep
!output/qwen2.5-7b-orpo-ecommerce-v1/
output/qwen2.5-7b-orpo-ecommerce-v1/report/training_report_cn.md
output/vllm_benchmark/deployment_validation_report.md

# ── IDE / 编辑器配置 ──
.idea/
.vscode/
*.swp
*.swo
*~
.project
.settings/

# ── 操作系统残留 ──
.DS_Store
Thumbs.db
desktop.ini

# ── Docker / 部署运行时数据 ──
hf_cache/
data/
!data/.gitkeep

# ── Jupyter Notebook checkpoint ──
.ipynb_checkpoints/

# ── 运行时截图与临时产物 ──
web/screenshots/
web/demo/
web/b2c-selection-agent-demo.zip
*.zip
lark_auth_qr.png
